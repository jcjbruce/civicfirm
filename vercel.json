{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/proposals/:path*", "destination": "/proposals/:path*" },
    { "source": "/((?!proposals/).*)", "destination": "/index.html" }
  ]
}
